# Watify backend configuration.
# Copy to backend/.env and adjust. NEVER commit backend/.env (gitignored).

# Server
WATIFY_HOST=127.0.0.1
WATIFY_PORT=8000
WATIFY_CORS_ORIGIN=http://localhost:3000

# Storage
WATIFY_APP_DB=app.db
WATIFY_WHATSAPP_DB=whatsapp.db

# Sending defaults
WATIFY_MIN_DELAY_S=3
WATIFY_MAX_DELAY_S=30
WATIFY_GROUP_MAX_CONTACTS=20

# Logging
WATIFY_LOG_LEVEL=INFO
WATIFY_LOG_FILE=../docs/.support/logs/backend.log
